generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  LAB_OWNER
  RECEPTION
  TECHNICIAN
  DENTIST
}

enum CaseStatus {
  RECEIVED
  WORKING
  TRIAL
  FINISHED
  DELIVERED
}

enum CasePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PaymentMethod {
  CASH
  UPI
  BANK
  ONLINE
  CHEQUE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum PlanTier {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum OrthoStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ToothStatus {
  HEALTHY
  TREATMENT_DONE
  ONGOING
  FILLING
  EXTRACTION
  PLANNED
  MISSING
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  emailVerified DateTime?
  password      String?
  name          String
  role          Role           @default(RECEPTION)
  phone         String?
  avatar        String?
  image         String?
  active        Boolean        @default(true)
  labId         String?
  lab           Lab?           @relation(fields: [labId], references: [id])
  notifications Notification[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([labId])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Lab {
  id            String          @id @default(cuid())
  name          String
  slug          String?         @unique
  address       String?
  phone         String?
  email         String?
  logo          String?
  currency      String          @default("USD")
  taxRate       Float           @default(0)
  plan          String          @default("trial")
  planTier      PlanTier        @default(TRIAL)
  planExpiresAt DateTime?
  trialEndsAt   DateTime?
  maxUsers      Int             @default(2)
  isActive      Boolean         @default(true)
  // Stripe fields
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  // Branding
  primaryColor  String          @default("#6366f1")
  tagline       String?
  website       String?
  timezone      String          @default("UTC")
  // SaaS tracking
  storageUsedMB Float           @default(0)
  onboardingComplete Boolean    @default(false)
  billingEmail  String?
  // Relations
  users               User[]
  branches            Branch[]
  dentists            Dentist[]
  patients            Patient[]
  cases               Case[]
  invoices            Invoice[]
  inventory           InventoryItem[]
  expenses            Expense[]
  appointments        Appointment[]
  prescriptions       Prescription[]
  staff               Staff[]
  pharmacyItems       PharmacyItem[]
  pharmacySales       PharmacySale[]
  orthodonticPlans    OrthodonticPlan[]
  dentalCharts        DentalChart[]
  medicalCertificates MedicalCertificate[]
  subscription        Subscription?
  invitations         Invitation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  labId     String
  lab       Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  cases     Case[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labId])
}

model Dentist {
  id         String    @id @default(cuid())
  name       String
  clinicName String?
  phone      String?
  whatsapp   String?
  email      String?
  address    String?
  balance    Float     @default(0)
  notes      String?
  active     Boolean   @default(true)
  labId            String
  lab              Lab               @relation(fields: [labId], references: [id], onDelete: Cascade)
  patients         Patient[]
  cases            Case[]
  invoices         Invoice[]
  payments         Payment[]
  appointments     Appointment[]
  prescriptions    Prescription[]
  orthodonticPlans OrthodonticPlan[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([labId])
  @@index([name])
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  age       Int?
  gender    String?
  phone     String?
  notes     String?
  dentistId String
  dentist   Dentist  @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  labId              String
  lab                Lab                 @relation(fields: [labId], references: [id], onDelete: Cascade)
  cases              Case[]
  appointments       Appointment[]
  prescriptions      Prescription[]
  medicalHistory     MedicalHistory?
  medicalCertificates MedicalCertificate[]
  pharmacySales      PharmacySale[]
  orthodonticPlans   OrthodonticPlan[]
  dentalCharts       DentalChart[]
  photos             PatientPhoto[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([dentistId])
  @@index([labId])
  @@index([name])
}

model Case {
  id           String           @id @default(cuid())
  caseNumber   String           @unique
  date         DateTime         @default(now())
  dentistId    String
  dentist      Dentist          @relation(fields: [dentistId], references: [id])
  patientId    String?
  patient      Patient?         @relation(fields: [patientId], references: [id])
  teethNumbers Int[]
  workType     String
  shade        String?
  material     String?
  technicianId String?
  dueDate      DateTime?
  priority     CasePriority     @default(NORMAL)
  status       CaseStatus       @default(RECEIVED)
  amount       Float            @default(0)
  remarks      String?
  labId        String
  lab          Lab              @relation(fields: [labId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?          @relation(fields: [branchId], references: [id])
  files        CaseFile[]
  invoices     Invoice[]
  usages       InventoryUsage[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([labId])
  @@index([dentistId])
  @@index([status])
  @@index([caseNumber])
  @@index([technicianId])
  @@index([date])
}

model CaseFile {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fileName  String
  fileType  String
  filePath  String
  fileSize  Int
  createdAt DateTime @default(now())

  @@index([caseId])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  caseId        String?
  case          Case?         @relation(fields: [caseId], references: [id])
  dentistId     String
  dentist       Dentist       @relation(fields: [dentistId], references: [id])
  amount        Float
  discount      Float         @default(0)
  tax           Float         @default(0)
  total         Float
  status        InvoiceStatus @default(DRAFT)
  notes         String?
  labId         String
  lab           Lab           @relation(fields: [labId], references: [id], onDelete: Cascade)
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([labId])
  @@index([dentistId])
  @@index([status])
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String?
  invoice   Invoice?      @relation(fields: [invoiceId], references: [id])
  dentistId String
  dentist   Dentist       @relation(fields: [dentistId], references: [id])
  amount    Float
  method    PaymentMethod @default(CASH)
  reference String?
  notes     String?
  date      DateTime      @default(now())
  createdAt DateTime      @default(now())

  @@index([dentistId])
  @@index([invoiceId])
}

model InventoryItem {
  id          String           @id @default(cuid())
  name        String
  category    String?
  stock       Float            @default(0)
  unit        String           @default("pcs")
  costPerUnit Float            @default(0)
  minStock    Float            @default(5)
  labId       String
  lab         Lab              @relation(fields: [labId], references: [id], onDelete: Cascade)
  usages      InventoryUsage[]
  purchases   PurchaseEntry[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([labId])
  @@index([name])
}

model InventoryUsage {
  id       String        @id @default(cuid())
  itemId   String
  item     InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  caseId   String?
  case     Case?         @relation(fields: [caseId], references: [id])
  quantity Float
  date     DateTime      @default(now())

  @@index([itemId])
  @@index([caseId])
}

model PurchaseEntry {
  id          String        @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity    Float
  costPerUnit Float
  totalCost   Float
  supplier    String?
  notes       String?
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())

  @@index([itemId])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String
  date        DateTime @default(now())
  notes       String?
  labId       String
  lab         Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([labId])
  @@index([date])
  @@index([category])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
}

model LoginActivity {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  userName  String?
  action    String   // "LOGIN_SUCCESS", "LOGIN_FAILED", "REGISTER", "OTP_VERIFIED", "LOGOUT"
  ipAddress String?
  userAgent String?
  details   String?  // Additional info like "Invalid password", "Email not verified"
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@index([action])
}

model Appointment {
  id           String            @id @default(cuid())
  patientId    String
  patient      Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dentistId    String
  dentist      Dentist           @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  labId        String
  lab          Lab               @relation(fields: [labId], references: [id], onDelete: Cascade)
  date         DateTime
  time         String
  duration     Int               @default(30)
  treatment    String
  status       AppointmentStatus @default(SCHEDULED)
  notes        String?
  reminderSent Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([patientId])
  @@index([dentistId])
  @@index([labId])
  @@index([date])
  @@index([status])
}

model Prescription {
  id        String             @id @default(cuid())
  patientId String
  patient   Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dentistId String?
  dentist   Dentist?           @relation(fields: [dentistId], references: [id])
  labId     String
  lab       Lab                @relation(fields: [labId], references: [id], onDelete: Cascade)
  date      DateTime           @default(now())
  notes     String?
  items     PrescriptionItem[]
  createdAt DateTime           @default(now())

  @@index([patientId])
  @@index([dentistId])
  @@index([labId])
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineName   String
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  createdAt      DateTime     @default(now())

  @@index([prescriptionId])
}

model MedicalHistory {
  id          String   @id @default(cuid())
  patientId   String   @unique
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  allergies   String?
  conditions  String?
  bloodGroup  String?
  notes       String?
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([patientId])
}

model MedicalCertificate {
  id             String    @id @default(cuid())
  patientId      String
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorName     String
  diagnosis      String
  restPeriodFrom DateTime
  restPeriodTo   DateTime
  fitnessDate    DateTime?
  notes          String?
  filePath       String?
  labId          String
  lab            Lab       @relation(fields: [labId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())

  @@index([patientId])
  @@index([labId])
}

model Staff {
  id         String         @id @default(cuid())
  name       String
  role       String
  phone      String
  email      String?
  salary     Float          @default(0)
  joinedDate DateTime
  status     StaffStatus    @default(ACTIVE)
  labId      String
  lab        Lab            @relation(fields: [labId], references: [id], onDelete: Cascade)
  attendance StaffAttendance[]
  payments   StaffPayment[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([labId])
}

model StaffAttendance {
  id        String           @id @default(cuid())
  staffId   String
  staff     Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())

  @@unique([staffId, date])
  @@index([staffId])
  @@index([date])
}

model StaffPayment {
  id         String        @id @default(cuid())
  staffId    String
  staff      Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date       DateTime
  amount     Float
  method     PaymentMethod @default(CASH)
  remarks    String?
  deductions Float         @default(0)
  bonuses    Float         @default(0)
  createdAt  DateTime      @default(now())

  @@index([staffId])
}

model PharmacyItem {
  id            String             @id @default(cuid())
  name          String
  genericName   String?
  category      String?
  batchNo       String?
  expiryDate    DateTime?
  quantity      Float              @default(0)
  mrp           Float              @default(0)
  purchasePrice Float              @default(0)
  minStock      Float              @default(5)
  supplier      String?
  rackLocation  String?
  labId         String
  lab           Lab                @relation(fields: [labId], references: [id], onDelete: Cascade)
  sales         PharmacySaleItem[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([labId])
  @@index([name])
}

model PharmacySale {
  id           String             @id @default(cuid())
  patientName  String?
  patientPhone String?
  patientId    String?
  patient      Patient?           @relation(fields: [patientId], references: [id])
  date         DateTime           @default(now())
  totalAmount  Float
  paymentMode  PaymentMethod      @default(CASH)
  doctorName   String?
  labId        String
  lab          Lab                @relation(fields: [labId], references: [id], onDelete: Cascade)
  items        PharmacySaleItem[]
  createdAt    DateTime           @default(now())

  @@index([patientId])
  @@index([labId])
  @@index([date])
}

model PharmacySaleItem {
  id        String        @id @default(cuid())
  saleId    String
  sale      PharmacySale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  itemId    String?
  item      PharmacyItem? @relation(fields: [itemId], references: [id])
  itemName  String
  quantity  Float
  price     Float
  total     Float
  createdAt DateTime      @default(now())

  @@index([saleId])
  @@index([itemId])
}

model OrthodonticPlan {
  id        String         @id @default(cuid())
  patientId String
  patient   Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dentistId String?
  dentist   Dentist?       @relation(fields: [dentistId], references: [id])
  diagnosis String
  totalCost Float
  startDate DateTime
  status    OrthoStatus    @default(ACTIVE)
  notes     String?
  labId     String
  lab       Lab            @relation(fields: [labId], references: [id], onDelete: Cascade)
  payments  OrthoPayment[]
  records   OrthoRecord[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([patientId])
  @@index([dentistId])
  @@index([labId])
}

model OrthoPayment {
  id        String          @id @default(cuid())
  planId    String
  plan      OrthodonticPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  date      DateTime
  amount    Float
  method    PaymentMethod   @default(CASH)
  notes     String?
  createdAt DateTime        @default(now())

  @@index([planId])
}

model OrthoRecord {
  id         String          @id @default(cuid())
  planId     String
  plan       OrthodonticPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  date       DateTime
  notes      String?
  imagePath  String?
  doctorName String?
  createdAt  DateTime        @default(now())

  @@index([planId])
}

model DentalChart {
  id             String      @id @default(cuid())
  patientId      String
  patient        Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  toothNumber    Int
  diagnosis      String?
  treatment      String?
  status         ToothStatus @default(HEALTHY)
  surface        String?
  completionDate DateTime?
  notes          String?
  labId          String
  lab            Lab         @relation(fields: [labId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([patientId])
  @@index([labId])
  @@index([toothNumber])
}

model PatientPhoto {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  filePath    String
  description String?
  toothNumber Int?
  dateAdded   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([patientId])
}

model Subscription {
  id                   String   @id @default(cuid())
  labId                String   @unique
  lab                  Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String   @unique
  stripePriceId        String
  stripeCustomerId     String
  status               String   // active, past_due, canceled, trialing
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([stripeCustomerId])
  @@index([status])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  labId     String
  lab       Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  role      Role     @default(RECEPTION)
  token     String   @unique
  expiresAt DateTime
  accepted  Boolean  @default(false)
  invitedBy String
  createdAt DateTime @default(now())

  @@unique([email, labId])
  @@index([token])
  @@index([labId])
}
